# Nginx Reverse Proxy Configuration
# Copy this file to .env and fill in your values

# ===================================
# Admin Configuration
# ===================================

# Required: Email for Let's Encrypt certificate notifications
# This email will receive expiry warnings and renewal failure alerts
ADMIN_EMAIL=admin@example.com

# ===================================
# General Configuration
# ===================================

# Timezone
TZ=America/Vancouver

# ===================================
# DEPLOYMENT INSTRUCTIONS
# ===================================
# 
# IMPORTANT: This stack must be deployed BEFORE Matrix
# 
# 1. Deploy in Portainer:
#    - Stack name: nginx
#    - Repository path: compose/nginx.yml
#    - Load this .env file
#    - Set ADMIN_EMAIL to your actual email
#
# 2. Verify deployment:
#    docker ps | grep nginx
#    # Should see both nginx-proxy and nginx-proxy-acme running
#
# 3. Check Let's Encrypt companion logs:
#    docker logs nginx-proxy-acme
#    # Should show "Docker containers being monitored"
#
# 4. The nginx-proxy automatically configures reverse proxy for containers
#    with the following labels:
#      VIRTUAL_HOST=subdomain.domain.com
#      VIRTUAL_PORT=8008
#      LETSENCRYPT_HOST=subdomain.domain.com
#      LETSENCRYPT_EMAIL=${ADMIN_EMAIL}
#
# 5. Certificates are stored in the nginx_certs volume
#    and automatically renewed before expiration
#
# ===================================
# Port Forwarding Requirements
# ===================================
# 
# Configure these port forwards on your router/firewall:
#   80 TCP → 192.168.1.10:80 (HTTP, Let's Encrypt validation)
#   443 TCP → 192.168.1.10:443 (HTTPS)
#
# ===================================
