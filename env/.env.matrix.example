# Matrix Synapse Homeserver Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Server Configuration
# ===========================================

# Required: Matrix server name (used for user IDs like @user:italicninja.com)
MATRIX_SERVER_NAME=italicninja.com

# Required: Domain for Matrix services
MATRIX_DOMAIN=italicninja.com

# Required: Admin email for Let's Encrypt notifications
ADMIN_EMAIL=admin@example.com

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL database settings
POSTGRES_DB=synapse
POSTGRES_USER=synapse
# Required: Strong password for PostgreSQL (generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ===========================================
# Registration Settings
# ===========================================

# Enable open registration with reCAPTCHA protection
ENABLE_REGISTRATION=true

# Required: reCAPTCHA keys (get from: https://www.google.com/recaptcha/admin)
# Use reCAPTCHA v2 ("I'm not a robot" checkbox)
RECAPTCHA_PUBLIC_KEY=YOUR_RECAPTCHA_SITE_KEY_HERE
RECAPTCHA_PRIVATE_KEY=YOUR_RECAPTCHA_SECRET_KEY_HERE

# ===========================================
# Security Secrets
# ===========================================

# Required: Generate these secrets using: openssl rand -hex 32
# Run the command 4 times to generate all 4 secrets

# Used for creating admin users via command line
REGISTRATION_SHARED_SECRET=GENERATE_RANDOM_SECRET_1

# Session security
MACAROON_SECRET_KEY=GENERATE_RANDOM_SECRET_2

# Form security
FORM_SECRET=GENERATE_RANDOM_SECRET_3

# TURN server authentication
TURN_SHARED_SECRET=GENERATE_RANDOM_SECRET_4

# ===========================================
# User Limits (Sane Defaults)
# ===========================================

# Maximum upload size for media
MAX_UPLOAD_SIZE=50M

# Rate limiting is configured in homeserver.yaml:
# - Message rate: 1/sec sustained, 10 burst
# - Registration: 3 accounts/hour per IP
# - Login attempts: 3 per account
# - Room joins: 0.1/sec local, 0.01/sec remote

# ===========================================
# TURN Server Configuration
# ===========================================

# Optional: External IP for TURN server (auto-detected if empty)
TURN_EXTERNAL_IP=

# TURN server realm (domain name)
TURN_REALM=turn.italicninja.com

# ===========================================
# Backup Configuration
# ===========================================

# Backup schedule (cron format)
# Default: Every 6 hours at minute 0
BACKUP_SCHEDULE=0 */6 * * *

# Number of days to retain backups
BACKUP_RETENTION_DAYS=7

# ===========================================
# General Configuration
# ===========================================

# Timezone
TZ=America/Vancouver

# ===========================================
# DEPLOYMENT INSTRUCTIONS
# ===========================================
# 
# PREREQUISITES:
# ✅ Nginx stack must be deployed first with Let's Encrypt enabled
# ✅ Pi-hole + Vercel DDNS stack should be running (optional but recommended)
#
# STEP 1: Create Data Directories
# --------------------------------
# Run these commands on your host:
#
#   sudo mkdir -p /data/matrix/{postgres,synapse,coturn}
#   sudo mkdir -p /backup/matrix
#   
#   # Set correct ownership (UID 991 for Synapse, UID 999 for PostgreSQL)
#   sudo chown -R 991:991 /data/matrix/synapse
#   sudo chown -R 999:999 /data/matrix/postgres
#   sudo chown -R 999:999 /data/matrix/coturn
#   sudo chown -R 999:999 /backup/matrix
#
# STEP 2: Get reCAPTCHA Keys
# ---------------------------
# 1. Visit: https://www.google.com/recaptcha/admin
# 2. Click "Create" or "+" to add new site
# 3. Label: Matrix Homeserver (italicninja.com)
# 4. reCAPTCHA type: Select "reCAPTCHA v2" → "I'm not a robot" Checkbox
# 5. Domains: Add "matrix.italicninja.com"
# 6. Accept terms and click "Submit"
# 7. Copy the "Site Key" to RECAPTCHA_PUBLIC_KEY above
# 8. Copy the "Secret Key" to RECAPTCHA_PRIVATE_KEY above
#
# STEP 3: Generate Security Secrets
# ----------------------------------
# Run this command 4 times and paste each result into the corresponding field above:
#
#   openssl rand -hex 32
#
# STEP 4: Configure DNS
# ----------------------
# A. Pi-hole Local DNS (manual):
#    - Access Pi-hole: https://pihole.italicninja.com:8443/admin
#    - Go to: Local DNS → DNS Records
#    - Add: matrix.italicninja.com → 192.168.1.10
#    - Add: admin.matrix.italicninja.com → 192.168.1.10
#
# B. Vercel Public DNS (automatic via enhanced DDNS):
#    - If you updated pihole-vercel stack with Matrix subdomain support:
#      Set MATRIX_SUBDOMAIN=matrix and MATRIX_ADMIN_SUBDOMAIN=admin.matrix
#      The DDNS service will automatically create A records
#
#    - If not using automatic DDNS, manually add to Vercel:
#      A record: matrix.italicninja.com → YOUR_PUBLIC_IP
#      A record: admin.matrix.italicninja.com → YOUR_PUBLIC_IP
#
# C. Vercel SRV Record (MANUAL - Required for Federation):
#    - Login to Vercel dashboard
#    - Go to your domain settings
#    - Add SRV record:
#      Name: _matrix._tcp.italicninja.com
#      Service: _matrix
#      Protocol: _tcp
#      Priority: 10
#      Weight: 0
#      Port: 8448
#      Target: matrix.italicninja.com
#
#    Note: The vercel-ddns service does not currently support SRV records.
#    This must be added manually in the Vercel dashboard.
#
# STEP 5: Configure Firewall Port Forwarding
# -------------------------------------------
# Add these port forwards on your router/firewall:
#
# | External Port | Internal IP    | Internal Port | Protocol | Service             |
# |---------------|----------------|---------------|----------|---------------------|
# | 80            | 192.168.1.10   | 80            | TCP      | HTTP (nginx)        |
# | 443           | 192.168.1.10   | 443           | TCP      | HTTPS (nginx)       |
# | 8448          | 192.168.1.10   | 8448          | TCP      | Matrix Federation   |
# | 3478          | 192.168.1.10   | 3478          | TCP+UDP  | TURN                |
# | 5349          | 192.168.1.10   | 5349          | TCP+UDP  | TURN TLS            |
# | 49152-49172   | 192.168.1.10   | 49152-49172   | UDP      | TURN Relay          |
#
# Note: Ports 80 and 443 should already be forwarded if nginx is running.
#
# STEP 6: Deploy Matrix Stack in Portainer
# -----------------------------------------
# 1. In Portainer, go to: Stacks → Add Stack → Git Repository
# 2. Configure:
#    - Stack name: matrix
#    - Repository URL: (your GitHub repo)
#    - Compose path: compose/matrix.yml
#    - Reference: main (or your branch)
# 3. Click "Load variables from .env file"
# 4. Select: env/.env.matrix.example
# 5. Edit all values marked with CHANGE_ME or YOUR_*
# 6. Ensure all 4 secrets are unique random values
# 7. Click "Deploy the stack"
#
# STEP 7: Monitor Deployment
# ---------------------------
# Watch the deployment progress (~5-10 minutes):
#
#   docker logs -f matrix-postgres    # PostgreSQL initialization
#   docker logs -f matrix-synapse     # Synapse config generation
#   docker logs -f matrix-coturn      # TURN server startup
#   docker logs -f nginx-proxy-acme   # Let's Encrypt certificate issuance
#
# Check all containers are healthy:
#
#   docker ps | grep matrix
#
# STEP 8: Create First Admin User
# --------------------------------
# After all services are running, create your first admin user:
#
#   docker exec -it matrix-synapse register_new_matrix_user \
#     -c /data/homeserver.yaml -a http://localhost:8008
#
# You will be prompted for:
#   - Username (e.g., "admin")
#   - Password
#   - Confirm admin privileges (yes)
#
# Your Matrix ID will be: @admin:italicninja.com
#
# STEP 9: Access Services
# ------------------------
# - Matrix Homeserver: https://matrix.italicninja.com
# - Admin Interface: https://admin.matrix.italicninja.com
# - Federation API: https://matrix.italicninja.com:8448
#
# STEP 10: Test Federation
# -------------------------
# 1. Visit: https://federationtester.matrix.org/
# 2. Enter your domain: italicninja.com
# 3. Click "Test"
# 4. Verify all checks pass (green checkmarks)
#
# Common issues:
# - SRV record not found → Check Vercel DNS SRV record
# - Port 8448 unreachable → Check firewall port forward
# - Certificate errors → Wait for Let's Encrypt provisioning
#
# STEP 11: Test Registration with Captcha
# ----------------------------------------
# 1. Download Element app (https://element.io) or use web client
# 2. Click "Create Account"
# 3. Click "Edit" next to homeserver
# 4. Enter: matrix.italicninja.com
# 5. Click "Continue"
# 6. Fill in username and password
# 7. Complete reCAPTCHA challenge
# 8. Account should be created successfully
#
# STEP 12: Test Voice/Video Calls
# --------------------------------
# 1. Create or join a room with another user
# 2. Start a voice or video call
# 3. Verify WebRTC connection works (TURN server)
# 4. Check coturn logs if issues: docker logs matrix-coturn
#
# STEP 13: Monitor First Backup
# ------------------------------
# Backups run every 6 hours. To manually trigger:
#
#   docker exec matrix-backup /usr/local/bin/backup.sh
#
# Check backup files:
#
#   ls -lh /backup/matrix/
#
# View backup logs:
#
#   docker logs matrix-backup
#
# ===========================================
# ENCRYPTION DETAILS
# ===========================================
#
# Network Encryption (Transport):
# ✅ PostgreSQL: TLS/SSL required for all connections (self-signed cert)
# ✅ Synapse ↔ PostgreSQL: Encrypted via SSL (sslmode=require)
# ✅ Client ↔ Synapse: HTTPS via Let's Encrypt (auto-renewing)
# ✅ Server ↔ Server: TLS on port 8448 (Matrix federation)
# ✅ TURN Server: TLS on port 5349 (voice/video calls)
#
# Data at Rest:
# ✅ Synapse media: Built-in media repository encryption
# ✅ PostgreSQL: Stored in /data/matrix/postgres (bind mount)
# ✅ Backups: Stored in /backup/matrix/ (bind mount)
#
# Recommendation: Use OS-level encryption (LUKS or BitLocker) for
# /data and /backup partitions for maximum data-at-rest security.
#
# ===========================================
# RESOURCE USAGE
# ===========================================
#
# Expected resource consumption:
# - CPU: ~4.4 cores total (2 for Synapse, 1 for PostgreSQL, 1 for Coturn)
# - RAM: ~7.4GB total (4GB Synapse, 2GB PostgreSQL, 1GB Coturn, 512MB others)
# - Disk (initial): ~1GB
# - Disk (growth): Varies based on usage
#   - Light (5-10 users): +1-2GB/month
#   - Medium (20-50 users): +5-10GB/month
#   - Heavy (100+ users): +20-50GB/month
#
# ===========================================
# MAINTENANCE
# ===========================================
#
# Monitor media storage growth:
#   du -sh /data/matrix/synapse/media_store
#
# Monitor database size:
#   docker exec matrix-postgres psql -U synapse -c "\l+"
#
# View active users:
#   Access admin interface: https://admin.matrix.italicninja.com
#
# Update containers:
#   1. In Portainer, go to Stacks → matrix
#   2. Click "Pull and redeploy"
#   3. Monitor logs for any issues
#
# ===========================================
# TROUBLESHOOTING
# ===========================================
#
# PostgreSQL SSL not working:
#   docker exec matrix-postgres psql -U synapse -c "SHOW ssl;"
#   # Should return "on"
#
# Synapse not starting:
#   docker logs matrix-synapse
#   # Check for database connection errors
#
# Federation not working:
#   - Verify SRV record: dig _matrix._tcp.italicninja.com SRV
#   - Check port 8448: telnet matrix.italicninja.com 8448
#   - Test: https://federationtester.matrix.org/
#
# TURN server not working:
#   docker logs matrix-coturn
#   # Check for IP detection errors
#   # Verify UDP ports are forwarded (not just TCP)
#
# Let's Encrypt certificate issues:
#   docker logs nginx-proxy-acme
#   # Check for rate limiting or validation errors
#
# Registration captcha not showing:
#   - Verify reCAPTCHA keys are correct
#   - Check browser console for errors
#   - Ensure domain matches reCAPTCHA configuration
#
# ===========================================
# NEXT STEPS
# ===========================================
#
# After successful deployment:
# 
# 1. Create additional user accounts via admin interface
# 2. Configure room permissions and moderation
# 3. Set up automated media cleanup (optional)
# 4. Add bridges for Discord/Telegram (future enhancement)
# 5. Deploy Element Web client (separate stack)
# 6. Configure email notifications (optional)
# 7. Set up monitoring with Prometheus/Grafana (optional)
#
# ===========================================
